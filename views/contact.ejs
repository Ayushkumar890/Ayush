<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/public/style.css">

    <link rel="icon" type="image/x-icon" href="/images/aaa.png">

    <title>Ayush-Portfolio</title>
</head>
<style>
    input[type=checkbox] {
        display: none;
    }

    .container img {

        transition: transform 0.85s ease;

    }

    input[type=checkbox]:checked~label>img {
        transform: scale(2);

    }

    html {
        scroll-behavior: smooth;
    }
</style>

<body class="bg-zinc-900 w-full">
    
    <div class="w-full mx">
        <h1 class="md:ml-10 font-bold text-3xl text-purple-700 mb-8">Contact</h1>
        <div class="max-w-6xl mx-auto bg-transparent rounded-lg ">
                <div class="bg-transparent w- full sm:w-[50%] p-6 rounded-lg mx-auto">
                    <form class="mt-8 space-y-4" method="post" action="/contact">
                        <input type='text' name="name" placeholder='Name'
                            class="w-full rounded-md py-3 px-4 text-sm outline-purple-400  border-2 border-purple-500 bg-transparent" />
                        <input type='email' name="email" placeholder='Email'
                            class="w-full rounded-md py-3 px-4 text-sm outline-purple-400  border-2 border-purple-500 peer bg-transparent" />
                        <input type='text' name="subject" placeholder='Subject'
                            class="w-full rounded-md py-3 px-4 text-sm outline-purple-400 border-2 border-purple-500 bg-transparent" />
                        <textarea placeholder='Message' name="message" rows="6"
                            class="w-full rounded-md px-4 text-sm pt-3 outline-purple-400 border-2 border-purple-500 bg-transparent"></textarea>
                        <input type='submit'
                            class="text-white bg-purple-600 hover:bg-purple-700 font-semibold rounded-md text-sm px-4 py-3 flex items-center justify-center w-full" />
                    </form>
                </div>
        </div>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/1.8.1/flowbite.min.js"></script>
</body>


</html>