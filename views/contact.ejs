<style>
    input[type=checkbox] {
        display: none;
    }

    .container img {

        transition: transform 0.85s ease;

    }

    input[type=checkbox]:checked~label>img {
        transform: scale(2);

    }

    html {
        scroll-behavior: smooth;
    }
</style>

<body class="bg-zinc-900 w-full">
    
    <div class="w-full mx">
    
        <h1 class="ml-10 mt-4 font-bold text-purple-200  md:mt-0 mb-10 text-4xl border-b-4  w-max border-purple-500 ">Contact</h1>
        <div class="max-w-6xl mx-auto bg-transparent rounded-lg ">
                <div class="bg-transparent w- full sm:w-[50%] p-6 rounded-lg mx-auto">
                    <form class="mt-8 space-y-4" method="post" action="/contact">
                        <input type='text' name="name" placeholder='Name'
                            class="w-full py-4 px-4 text-md text-white outline-none  border-b-2 border-purple-500 bg-transparent" />
                            <br>
                            <input type='email' name="email" placeholder='Email'
                            class="w-full py-4 px-4 text-md text-white outline-none  border-b-2 border-purple-500 peer bg-transparent" />
                            <br>
                            <input type='text' name="subject" placeholder='Subject'
                            class="w-full py-4 px-4 text-md text-white outline-none border-b-2 border-purple-500 bg-transparent" />
                            <br>
                            <textarea placeholder='Message' name="message" rows="6"
                            class="w-full px-4 text-md text-white pt-3 outline-none border-b-2 border-purple-500 bg-transparent"></textarea>
                            <br>
                        <input type='submit'
                            class="text-white bg-purple-600 hover:bg-purple-700 font-semibold text-md  px-4 py-3 flex items-center justify-center w-full" />
                    </form>
                </div>
        </div>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/1.8.1/flowbite.min.js"></script>
</body>


</html>